# ─────────────────────────────────────────
#  TuHora Backend — Variables de entorno
#  Copiar a .env y completar los valores
# ─────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# Database (Postgres vía Docker o Railway)
DATABASE_URL="postgresql://tuhora:tuhora_secret@localhost:5432/tuhora_dev?schema=public"

# Docker Postgres (usado en docker-compose.yml)
POSTGRES_USER=tuhora
POSTGRES_PASSWORD=tuhora_secret
POSTGRES_DB=tuhora_dev

# JWT — generá tus propios secrets con: openssl rand -hex 64
JWT_ACCESS_SECRET=cambia_este_secret_por_uno_seguro_de_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_este_refresh_secret_tambien
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Mercado Pago (Fase 3)
MP_ACCESS_TOKEN=TEST-xxx
MP_PUBLIC_KEY=TEST-xxx

# Firebase (push notifications — Fase 3)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Email (Fase 3 — usar Resend o SendGrid)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=noreply@tuhora.app
